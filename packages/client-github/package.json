{
  "name": "@ingitdb/client-github",
  "version": "0.1.0",
  "description": "inGitDB client implementation using the GitHub REST API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["ingitdb", "github", "git", "database", "client"],
  "license": "MIT",
  "dependencies": {
    "@ingitdb/client": "workspace:*"
  },
  "peerDependencies": {
    "@ingr/codec": "^0.0.1",
    "axios": "^1.8.4",
    "idb": "^8.0.2"
  },
  "devDependencies": {
    "@ingr/codec": "^0.0.1",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^3.0.8",
    "axios": "^1.8.4",
    "happy-dom": "^20.8.3",
    "idb": "^8.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.8"
  }
}
