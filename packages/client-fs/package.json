{
  "name": "@ingitdb/client-fs",
  "private": true,
  "version": "0.1.0",
  "description": "inGitDB client for local git repositories (filesystem access)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["ingitdb", "git", "database", "client", "filesystem"],
  "license": "MIT",
  "dependencies": {
    "@ingitdb/client": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.8",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.8"
  }
}
